# Database URL (optional - not required for current deployment)
DATABASE_URL="postgresql://user:password@localhost:5432/yumesorai?schema=public"

# API Configuration
NODE_ENV="development"

# ========================================
# GITHUB WEBHOOK CONFIGURATION
# ========================================

# GitHub Webhook Secret (use a strong random string, minimum 32 characters)
# Generate with: openssl rand -hex 32
# Used to verify webhook signatures from GitHub
GITHUB_WEBHOOK_SECRET="your_webhook_secret_here_32_chars_min"

# GitHub Configuration (optional - for webhook integration)
GITHUB_OWNER="prakhar1234"
GITHUB_REPO="yumesorai"
GITHUB_TOKEN="your_github_personal_access_token"

# ========================================
# RAILWAY DEPLOYMENT MONITORING
# ========================================

# Railway API Configuration (for deployment monitoring)
RAILWAY_PROJECT_ID="your_railway_project_id"
RAILWAY_ENVIRONMENT_ID="your_railway_environment_id"
RAILWAY_API_TOKEN="your_railway_api_token"

# ========================================
# TESTING CONFIGURATION
# ========================================

# Base URL for E2E tests
TEST_BASE_URL="https://yourdomain.com"
TEST_HEADLESS="true"

# ========================================
# NOTIFICATIONS (OPTIONAL)
# ========================================

# Slack Webhook URL for test notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Email Configuration
EMAIL_FROM="testing@yourdomain.com"
EMAIL_TO="team@yourdomain.com"
